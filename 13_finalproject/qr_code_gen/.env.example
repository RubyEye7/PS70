# Copy to .env in this folder and fill in real values. Do not commit .env.
#
# Google AI (Gemini): https://aistudio.google.com/app/apikey
# Spotify Web API:   https://developer.spotify.com/dashboard (create an app)

# Used for vision / song JSON. GEMINI_API_KEY is an accepted alias.
GOOGLE_API_KEY=
# GEMINI_API_KEY=

SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=

# Optional; pipeline defaults to gemini-3-flash-preview if unset
GEMINI_MODEL=gemini-3-flash-preview
